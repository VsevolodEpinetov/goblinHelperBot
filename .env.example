# Telegram
TOKEN=

# PostgreSQL
# If DB_* are unset, the app falls back to the standard libpq vars
# (PGHOST/PGPORT/PGDATABASE/PGUSER/PGPASSWORD), so an existing libpq-style
# environment works without renaming. DB_* take precedence when set.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=goblin_bot
DB_TEST_NAME=goblin_test
DB_USER=goblin
DB_PASSWORD=

# Main community group (the permanent lair chat). Used to scope XP, to mint the
# one-time main-group invite link a member gets on their first payment, and as
# the chat where raid cards are posted.
# REQUIRED when NODE_ENV=production — the bot refuses to start without it.
MAIN_GROUP_ID=

# Optional topic (message_thread_id) inside MAIN_GROUP_ID where raid cards are
# posted. Leave empty to post to the group's General topic. A raid keeps a
# single card here; it's deleted+reposted (bumped) whenever it changes.
RAIDS_TOPIC_ID=

# Optional topic (message_thread_id) inside MAIN_GROUP_ID where new kickstarter
# cards are announced. Leave empty to post to the group's General topic.
KICKSTARTERS_TOPIC_ID=

# Optional topic (message_thread_id) inside MAIN_GROUP_ID — the public RPG
# board where XP gains (10+) and level-ups are announced for everyone. Leave
# empty to fall back to private DM notifications.
RPG_TOPIC_ID=

# Optional topic (message_thread_id) inside MAIN_GROUP_ID where studio voting
# polls are posted when an admin launches them. Leave empty to post to the
# group's General topic.
POLLS_TOPIC_ID=

# Admin / council
# Chat (group/channel id) that receives new-application notifications and SBP
# payment requests, with inline approve/reject buttons. Required for the
# onboarding admin notification and the SBP flow.
# REQUIRED when NODE_ENV=production — the bot refuses to start without it.
ADMIN_NOTIFICATIONS_CHAT=

# Subscriptions (optional; defaults in code)
# REGULAR_PRICE=350
# PLUS_PRICE=1000
# TEST_USER_ID=

# СБП payments (optional). Integer RUB prices per tier; when set, СБП buttons,
# the screenshot prompt and the admin review card show the expected amount
# (past months cost ×3, same as Stars). SBP_REQUISITES is free text shown to
# the member — where to send the money (recipient / phone / bank).
# SBP_PRICE_REGULAR_RUB=
# SBP_PRICE_PLUS_RUB=
# SBP_REQUISITES=

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Session backend
USE_REDIS_SESSIONS=true

# Observability (optional)
SENTRY_DSN=
LOG_LEVEL=info

# Runtime
NODE_ENV=development

# Notion (optional, currently dropped from scope)
# NOTION_TOKEN=
# NOTION_DB=
